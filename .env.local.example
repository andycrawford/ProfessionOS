# ──────────────────────────────────────────────────────────────────────────────
# Profession OS — local development environment variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local — it is gitignored.
#
# For production/preview, set these in the Vercel dashboard under
# Settings → Environment Variables.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database (Neon) ────────────────────────────────────────────────────────────
# Neon serverless Postgres connection string.
# Get it from: Neon console → your project → Connection Details → Pooled connection.
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ── NextAuth v5 ────────────────────────────────────────────────────────────────
# AUTH_SECRET: random 32-byte base64 value.
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-random-32-byte-secret-here

# Application base URL (no trailing slash). NextAuth v5 reads AUTH_URL;
# NEXTAUTH_URL is still accepted as a fallback for backwards compatibility.
# Dev: http://localhost:3000
# Prod: https://app.professionos.com
AUTH_URL=http://localhost:3000

# ── Google OAuth ───────────────────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: {AUTH_URL}/api/auth/callback/google
AUTH_GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
AUTH_GOOGLE_SECRET=your-google-client-secret

# ── Microsoft (Azure AD / Entra ID) OAuth ─────────────────────────────────────
# Register app at: https://portal.azure.com → Azure Active Directory → App registrations
# Redirect URI: {AUTH_URL}/api/auth/callback/microsoft-entra-id
AUTH_MICROSOFT_ENTRA_ID_ID=your-azure-client-id
AUTH_MICROSOFT_ENTRA_ID_SECRET=your-azure-client-secret
# Use "common" for personal + org Microsoft accounts (default), or a specific
# Directory (tenant) ID to restrict to a single organization.
AUTH_MICROSOFT_ENTRA_ID_TENANT_ID=common

# ── Apple Sign In ──────────────────────────────────────────────────────────────
# Set up at: https://developer.apple.com → Certificates, IDs & Profiles → Services → Sign In with Apple
# Redirect URI: {AUTH_URL}/api/auth/callback/apple
# Apple requires HTTPS — does not work on http://localhost.
AUTH_APPLE_ID=your-apple-services-id
# Apple secret is a PKCS8 private key (.p8 file contents), used to sign a JWT.
# Generate with: npx auth add apple (will prompt for key details and write to .env.local)
AUTH_APPLE_SECRET=your-apple-private-key-p8-contents

# ── Encryption (at-rest secrets) ───────────────────────────────────────────────
# 32-byte hex-encoded key used to encrypt org SSO client secrets (and any other
# secrets stored encrypted in the DB). Generate with: openssl rand -hex 32
# If omitted, AUTH_SECRET is used as a fallback (first 32 bytes, base64-decoded).
# Set an explicit ENCRYPTION_KEY in production so you can rotate it independently
# of the NextAuth signing secret.
ENCRYPTION_KEY=your-64-hex-char-encryption-key-here
